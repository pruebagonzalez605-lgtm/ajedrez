# OAuth credentials (from Kick developer console)
KICK_CLIENT_ID=""
KICK_CLIENT_SECRET=""

# Must match exactly what you register in Kick
KICK_REDIRECT_URI="https://your-backend-domain.com/auth/kick/callback"

# Frontend origin for redirect after login (Vercel domain)
APP_ORIGIN="https://your-frontend-domain.vercel.app"

# Optional: custom scopes and endpoints
KICK_SCOPE="user:read channel:read channel:write chat:write streamkey:read events:subscribe moderation:ban kicks:read"
KICK_AUTH_URL="https://id.kick.com/oauth/authorize"
KICK_TOKEN_URL="https://id.kick.com/oauth/token"
KICK_USERINFO_URL="https://api.kick.com/public/v1/users"

# Server port (most hosts set PORT automatically)
PORT=3000