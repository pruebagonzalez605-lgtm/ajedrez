{
  "version": 2,
  "builds": [
    {
      "src": "api/auth/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/auth/kick",
      "dest": "/api/auth/kick.js"
    },
    {
      "src": "/api/auth/callback",
      "dest": "/api/auth/callback.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
